# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# service_role: solo server (crons, admin). NUNCA exponer al browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth: se configura en Supabase Dashboard, NO aquí
# Ver: Supabase Dashboard > Authentication > Providers > Google

# --- Motor (fases siguientes; aún no requeridas en Fase 0) ---
# WhatsApp Cloud API (Tech Provider / Embedded Signup) — Fase 1
# META_APP_SECRET=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# Telegram — Fase 1
# TELEGRAM_BOT_TOKEN=
# IA (router / provider) — Fase 3
# OPENROUTER_API_KEY=
# Stripe (cobro por software) — Fase 7
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Crons
# CRON_SECRET=
