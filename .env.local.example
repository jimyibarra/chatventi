# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# service_role: solo server (crons, admin). NUNCA exponer al browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth: se configura en Supabase Dashboard, NO aquí
# Ver: Supabase Dashboard > Authentication > Providers > Google

# --- Motor (fases siguientes) ---
# WhatsApp Cloud API (Tech Provider / Embedded Signup) — Fase 1
# App de Meta de ChatVenti (creada 2026-07-03). App ID es público (SDK frontend).
NEXT_PUBLIC_META_APP_ID=2268338090636391
# META_APP_SECRET=            # secreto: Settings > Básica > Mostrar (server only). Firma el webhook.
# META_WEBHOOK_VERIFY_TOKEN=  # token que TÚ inventas; debe coincidir con el configurado en Meta (GET webhook)
# META_CONFIG_ID=             # configuration_id del flujo Embedded Signup (FB.login del frontend). PENDIENTE.
# META_SYSTEM_USER_TOKEN=     # token del System User del Tech Provider (subscribe WABA / register número). PENDIENTE.
# Telegram — Fase 1
# TELEGRAM_BOT_TOKEN=         # token del bot (BotFather). Usado por set-webhook.
# TELEGRAM_WEBHOOK_SECRET=    # secreto que TÚ inventas; Telegram lo devuelve en el header X-Telegram-Bot-Api-Secret-Token
# TELEGRAM_BOT_EXTERNAL_ID=   # external_id del canal Telegram (bot id) para el enrutado en Fase 1 (un bot global)
# IA (router / provider) — Fase 3
# OPENROUTER_API_KEY=
# Stripe (cobro por software) — Fase 7
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Crons — protege endpoints server (p. ej. set-webhook de Telegram). Header: Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=
